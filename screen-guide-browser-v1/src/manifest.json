{
  "manifest_version": 3,
  "name": "AI Screen Guide",
  "version": "0.1.0",
  "description": "AI-guided browser workflows — highlights the next element to click",
  "permissions": ["sidePanel", "scripting", "tabs", "storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["vendor/driver.js", "content.js"],
    "css": ["vendor/driver.css"],
    "all_frames": true,
    "run_at": "document_idle"
  }],
  "side_panel": { "default_path": "panel.html" },
  "web_accessible_resources": [{ "resources": ["vendor/*"], "matches": ["<all_urls>"] }]
}
